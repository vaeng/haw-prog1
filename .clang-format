# LLVM base is a common C++ default; explicit overrides below reduce team churn.
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4
# 100 keeps lines readable on split views without forcing excessive wrapping.
ColumnLimit: 100
# Keep include ordering deterministic across platforms/LLVM versions.
SortIncludes: CaseSensitive
Standard: Latest