# -----------------------------
# Build system output (CMake/Ninja)
# -----------------------------
# Team policy: build outputs are local-only. Preferred folders are build/debug and build/release.
/build/
/build_*/
/out/
/.cache/
/.cmake/

# In-source CMake artifacts (if someone configures in the repo root by mistake).
/CMakeCache.txt
/CMakeFiles/
/cmake_install.cmake
/CTestTestfile.cmake
/Testing/
/install_manifest.txt

# Generated compilation database copied by VS Code CMake Tools.
/compile_commands.json


# -----------------------------
# Local machine overrides
# -----------------------------
# Personal preset overrides belong to each developer and should not be shared.
/CMakeUserPresets.json


# -----------------------------
# VS Code files
# -----------------------------
# Ignore local/editor-personal files by default, but keep shared project settings.
/.vscode/*
!/.vscode/settings.json
!/.vscode/tasks.json


# -----------------------------
# Compiler/cache artifacts
# -----------------------------
# Common local caches and object/binary outputs.
/.sccache/
/.ccache/
*.obj
*.o
*.pch
*.pdb
*.ilk
*.exe
*.out
*.a
*.lib
*.so
*.dylib
*.dll


# -----------------------------
# OS noise
# -----------------------------
.DS_Store
Thumbs.db
desktop.ini
